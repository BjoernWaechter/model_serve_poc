# Template for terraform.tfvars. Copy this file to terraform.tfvars and
# fill in real values. terraform.tfvars is gitignored.
#
#   cp terraform.tfvars.example terraform.tfvars

# Route 53 hosted zone ID for the public domain.
# Find with: aws route53 list-hosted-zones --query 'HostedZones[].{Name:Name,Id:Id}'
# The domain name itself is read from the zone at plan/apply time, so you
# don't need to set it here.
route53_zone_id = "ZXXXXXXXXXXXXX"

# Optional: GitHub credentials for Argo CD. Leave both empty to fall back to
# unauthenticated public-repo access (subject to GitHub's stricter rate limits).
# PAT scope needed: `repo` for private repos, `public_repo` for public-only.
# argocd_github_url_prefix = "https://github.com/your-org"
# argocd_github_pat        = "ghp_xxxxxxxxxxxxxxxxxxxx"

# Optional: per-team namespaces + AppProjects. Map key is the namespace name.
# Unset = three demo teams (team-a, team-b, team-platform) with default quotas
# and no AppProjects. Setting `source_repos` on a team enables its AppProject;
# resource_quota / limit_range accept per-field overrides (see variables.tf).
# teams = {
#   team-a = {
#     source_repos = ["https://github.com/your-org/models-iris.git"]
#     oidc_groups  = ["your-org:team-iris"]
#     resource_quota = {
#       requests_gpu = "8"   # override the "4" default
#       limits_gpu   = "8"
#     }
#   }
#   team-b = {
#     source_repos = ["https://github.com/your-org/models-fraud.git"]
#   }
#   team-platform = {}       # namespace + default quotas, no AppProject
# }
